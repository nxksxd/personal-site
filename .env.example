# Frontend → backend API base URL.
# Dev default (when unset) is http://localhost:8000.
# In production set this to the deployed backend URL, e.g. https://api.example.com
VITE_API_URL=http://localhost:8000

# ── Backend ────────────────────────────────────────────────────────────
# Secret used to sign admin JWTs. MUST be set to a strong random value in
# production — the app refuses to start otherwise (APP_ENV=production).
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Deployment environment. "production"/"prod" enables fail-closed checks
# (e.g. rejecting the insecure default JWT_SECRET). Use "dev" locally.
APP_ENV=production

# Writable data directory (SQLite DB + uploads live here).
DATA_DIR=/data
